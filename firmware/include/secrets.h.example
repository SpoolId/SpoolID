#pragma once
// Copy to secrets.h and fill in. secrets.h is git-ignored.
// These are only first-boot defaults; runtime values live in NVS.

#define DEFAULT_WIFI_SSID ""
#define DEFAULT_WIFI_PASS ""

// Fallback access point shown when STA can't connect.
#define DEFAULT_AP_SSID "SpoolID"
#define DEFAULT_AP_PASS "spoolid123"  // >=8 chars, or "" for an open AP

// mDNS hostname -> reachable at <hostname>.local
#define DEFAULT_HOSTNAME "spoolid"

#define DEFAULT_LOG_LEVEL LOG_INFO
#define DEFAULT_BAUD 115200
